{
  "enabledPlugins": {
    "skill-alpha@claude-skill-marketplace-demo-2": true,
    "skill-bravo@claude-skill-marketplace-demo-2": true,
    "skill-charlie@claude-skill-marketplace-demo-2": true
  },
  "extraKnownMarketplaces": {
    "claude-skill-marketplace-demo-2": {
      "source": {
        "source": "github",
        "repo": "businessfawcett-cloud/claude-skill-marketplace-demo-2"
      },
      "autoUpdate": true
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR}\" && claude plugin marketplace update || true"
          }
        ]
      }
    ]
  }
}
